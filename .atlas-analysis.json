  "keyFeatures": [
    "Transaction tracking and management with filtering and bulk editing",
    "Multi-account support for tracking different bank accounts and wallets",
    "Subscription tracking for recurring payments",
    "Custom dashboards with drag-and-drop widgets and data visualizations",
    "Budget management and expense categorization",
    "Organization/team support with role-based access control",
    "Authentication via email/password and Google OAuth",
    "Billing integration with Polar for Pro and Teams subscription plans",
    "PostgREST-based REST API with JWT authentication",
    "PostgreSQL database with comprehensive access control"
  ],
  "publicApiSurface": [
    "POST /api/auth/sign-up - Create new user account",
    "POST /api/auth/sign-in - Authenticate user",
    "GET /api/auth/session - Get current session",
    "POST /api/auth/sign-out - End user session",
    "GET /transactions - List transactions with filtering",
    "POST /transactions - Create new transaction",
    "PATCH /transactions - Update transaction",
    "DELETE /transactions - Delete transaction",
    "GET /accounts - List accounts",
    "POST /accounts - Create new account",
    "GET /subscriptions - List subscriptions",
    "POST /subscriptions - Create subscription",
    "GET /organizations - List organizations",
    "POST /organizations - Create organization",
    "GET /dashboards - List dashboard views",
    "POST /dashboards - Create custom dashboard"
  ]
